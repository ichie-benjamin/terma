{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terma",
  "version": "0.1.0",
  "identifier": "com.queek.terma",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Terma",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGOEJFQUMyREM4NTk1NUYKUldSZmxZWGN3dXFMTDVSdGpDNnBkSW1EUjUvNmo3SDQvYVRBQVRLekk5QmhmNW9uUFFGWlduK1QK",
      "endpoints": [
        "https://github.com/user/terma/releases/latest/download/latest.json"
      ]
    }
  }
}
